{
  "name": "web24",
  "version": "0.1.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --parallel dev:web dev:api",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:legacy": "next dev",
    "build": "bun run build:web && bun run build:api",
    "build:web": "bun run --cwd apps/web build",
    "build:api": "bun run --cwd apps/api build",
    "preview:web": "bun run --cwd apps/web preview",
    "typecheck": "bun run typecheck:web && bun run typecheck:api",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "typecheck:api": "bun run --cwd apps/api typecheck",
    "lint": "bun run lint:web && bun run lint:api",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:api": "bun run --cwd apps/api lint",
    "legacy:build": "next build",
    "legacy:start": "next start",
    "legacy:lint": "next lint",
    "cf:build": "opennextjs-cloudflare build",
    "cf:deploy": "wrangler deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "sync-trakt": "bun run scripts/sync-trakt.ts",
    "trakt:login": "bun run scripts/trakt-auth.ts login",
    "spotify:login": "bun run scripts/spotify-auth.ts login"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.16.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@vercel/analytics": "^1.4.1",
    "baseline-browser-mapping": "^2.10.8",
    "caniuse-lite": "^1.0.30001780",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.1",
    "date-fns-tz": "^3.2.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.552.0",
    "next": "15.5.12",
    "next-seo": "6.1.0",
    "notion-client": "^7.1.5",
    "patch-package": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-notion-x": "^7.8.2",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.17.8",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.12",
    "postcss": "^8.4.49",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "wrangler": "^4.67.0"
  },
  "packageManager": "bun@1.2.23"
}
