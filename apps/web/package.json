{
  "name": "@web24/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "tsc -p tsconfig.app.json && bunx --bun vite build && bun run prerender",
    "preview": "bunx --bun vite preview",
    "prerender": "bun run ./scripts/prerender.tsx",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "lint": "tsc -p tsconfig.app.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@web24/config": "workspace:*",
    "@web24/content": "workspace:*",
    "lucide-react": "^0.552.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/devtools": "^0.0.0-alpha.33",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0"
  }
}
